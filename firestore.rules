rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- BASIC AUTH HELPERS ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // Direct check for hardcoded administrators to bypass database lookups
    function isKnownAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "shwetank.chauhan17@gmail.com" || 
              request.auth.token.email == "shwetank.chauhan3@gmail.com" || 
              request.auth.token.email == "code4sarthak@gmail.com");
    }

    // Helper to check if current user matches an ID (UID or Email)
    function isUser(id) {
      return isAuthenticated() && id != null && id != "" && (
        request.auth.uid == id || 
        request.auth.token.email == id
      );
    }

    // Safer User Profile Fetch
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }

    // Check if the current user is a global Premium user (allowed to create events)
    function isPremiumUser() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "premium" || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    // Check if the current user is any type of admin
    function isAdmin() {
      return isKnownAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == "admin"
      );
    }

    // Check if the current user is a global Super Admin
    function isSuperAdmin() {
      return isKnownAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == "admin" && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('delegatedBy', '') == '')
      );
    }

    // Authorizes management if user is direct owner OR authorized admin
    function isManagementAuthorized(ownerId) {
      return isKnownAdmin() || (
        isAuthenticated() && (
          isUser(ownerId) || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
             // 1. Global Platform Admin (Self-created)
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" && 
              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('delegatedBy', null) == null || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('delegatedBy', '') == "")) || 
             // 2. Delegated Primary Admin (Management right given by owner, role-agnostic)
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('delegatedBy', null) == ownerId && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('roleType', '') == "primary")
          ))
        )
      );
    }

    // Check if user is an event admin for a specific event
    function isEventAdmin(eventId) {
      return isKnownAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedEvents', []).hasAny([eventId])
      );
    }

    // Check if user is a guest admin for a specific event
    function isGuestEventAdmin(eventId) {
      return isAuthenticated() && (
        // Case 1: checked by uid
        (exists(/databases/$(database)/documents/guests/$(request.auth.uid + "_" + eventId)) &&
         get(/databases/$(database)/documents/guests/$(request.auth.uid + "_" + eventId)).data.get('canAdmin', false) == true &&
         get(/databases/$(database)/documents/guests/$(request.auth.uid + "_" + eventId)).data.get('status', '') == 'approved') ||
        
        // Case 2: checked by email
        (request.auth.token.email != null &&
         exists(/databases/$(database)/documents/guests/$(request.auth.token.email + "_" + eventId)) &&
         get(/databases/$(database)/documents/guests/$(request.auth.token.email + "_" + eventId)).data.get('canAdmin', false) == true &&
         get(/databases/$(database)/documents/guests/$(request.auth.token.email + "_" + eventId)).data.get('status', '') == 'approved') ||
         
        // Case 3: checked by phone from user profile
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('phone', '') != '' &&
         exists(/databases/$(database)/documents/guests/$(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('phone', '') + "_" + eventId)) &&
         get(/databases/$(database)/documents/guests/$(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('phone', '') + "_" + eventId)).data.get('canAdmin', false) == true &&
         get(/databases/$(database)/documents/guests/$(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('phone', '') + "_" + eventId)).data.get('status', '') == 'approved')
      );
    }

    // Helper to extract owner ID from document data
    function getDocOwnerId(data) {
      return data.get('createdBy', data.get('userId', ''));
    }

    // --- COLLECTION RULES ---

    // --- BUSINESS RULES ---
    match /businesses/{bizId} {
      allow read: if true;
      allow create, delete: if isAuthenticated() && (
        isKnownAdmin() || 
        isAdmin() || 
        (resource == null || resource.data.createdBy == request.auth.uid)
      );
      allow update: if isAuthenticated() && (
        isKnownAdmin() || 
        isAdmin() || 
        (resource.data.createdBy == request.auth.uid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vendorCode', 'rating']))
      );
    }

    // --- ENQUIRIES & LEADS RULES ---
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated() && (
        isKnownAdmin() ||
        isAdmin() ||
        resource.data.userId == request.auth.uid ||
        resource.data.vendorOwnerId == request.auth.uid ||
        resource.data.vendorOwnerEmail == request.auth.token.email
      );
    }

    // --- CHAT ROOMS & MESSAGES RULES ---
    match /chatRooms/{roomId} {
      allow create: if isAuthenticated() && (
        request.resource.data.clientUid == request.auth.uid ||
        request.resource.data.vendorUid == request.auth.uid
      );
      allow read: if isAuthenticated() && (
        resource.data.clientUid == request.auth.uid ||
        resource.data.vendorUid == request.auth.uid ||
        isKnownAdmin() ||
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        isKnownAdmin() ||
        isAdmin() ||
        (
          (resource.data.clientUid == request.auth.uid || resource.data.vendorUid == request.auth.uid) &&
          (
            // Client is closing the chat room
            (resource.data.clientUid == request.auth.uid && request.resource.data.get('status', 'active') == 'closed') ||
            // Normal message-related updates on active, non-expired chat room
            (
              resource.data.get('status', 'active') == 'active' &&
              request.time < resource.data.createdAt + duration.value(48, 'h')
            )
          )
        )
      );
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.clientUid == request.auth.uid ||
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.vendorUid == request.auth.uid ||
          isKnownAdmin() ||
          isAdmin()
        );
        allow create: if isAuthenticated() && (
          (get(/databases/$(database)/documents/chatRooms/$(roomId)).data.clientUid == request.auth.uid ||
           get(/databases/$(database)/documents/chatRooms/$(roomId)).data.vendorUid == request.auth.uid) &&
          get(/databases/$(database)/documents/chatRooms/$(roomId)).data.get('status', 'active') == 'active' &&
          request.time < get(/databases/$(database)/documents/chatRooms/$(roomId)).data.createdAt + duration.value(48, 'h')
        );
      }
    }

    match /businessActivities/{activityId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() && (
        isKnownAdmin() ||
        isAdmin() ||
        (resource == null || resource.data.createdBy == request.auth.uid) ||
        (request.resource != null && request.resource.data.createdBy == request.auth.uid)
      );
    }

    match /businessRatings/{ratingId} {
      allow read: if true;
      allow create, update: if isAuthenticated() && 
                            ratingId == request.auth.uid + "_" + request.resource.data.businessId &&
                            request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if true;
      
      allow create: if isAuthenticated() && (
        isKnownAdmin() ||
        // 1. Root Event: any authenticated user can create a root event (gallery)
        (request.resource.data.get('parentId', null) == null && isUser(getDocOwnerId(request.resource.data))) ||
        // 2. Sub Event: Authorized for the parent's creator ID
        (request.resource.data.get('parentId', null) != null && 
         exists(/databases/$(database)/documents/events/$(request.resource.data.parentId)) &&
         isManagementAuthorized(getDocOwnerId(get(/databases/$(database)/documents/events/$(request.resource.data.parentId)).data)))
      );
      
      allow update, delete: if isKnownAdmin() || isManagementAuthorized(getDocOwnerId(resource.data)) || isEventAdmin(eventId) || isGuestEventAdmin(eventId);
      
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if isKnownAdmin() || isManagementAuthorized(getDocOwnerId(get(/databases/$(database)/documents/events/$(eventId)).data)) || isEventAdmin(eventId) || isGuestEventAdmin(eventId);
      }
    }

    match /photos/{photoId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        isKnownAdmin() || 
        request.auth.uid == request.resource.data.userId ||
        isManagementAuthorized(getDocOwnerId(request.resource.data))
      );
      allow update, delete: if isKnownAdmin() || isManagementAuthorized(getDocOwnerId(resource.data)) || isEventAdmin(resource.data.get('eventId', '')) || isGuestEventAdmin(resource.data.get('eventId', ''));
    }

    match /faces/{faceId} {
      allow read: if true;
      allow write: if isKnownAdmin() || isAdmin();
    }

    match /allowed_users/{phone} {
      allow get: if true; // Allow checking if user exists
      allow list: if isKnownAdmin() || isAdmin();
      allow write: if isKnownAdmin() || isAdmin();
    }

    match /pending_requests/{phone} {
      allow create: if true; // Allow guests to request access
      allow read, update, delete: if isKnownAdmin() || isAdmin();
    }

    match /guests/{logId} {
      // 1. Read: Anyone can check their status if they know the document ID
      allow get: if true;
      
      // 2. Create: New guest requests allowed
      allow create: if true;
      
      // 3. Update: Visitors can only refresh their record if their status remains exactly the same
      // (This allows loginAt updates but prevents self-approval)
      allow update: if (request.resource.data.get('status', 'pending') == resource.data.get('status', 'pending')) ||
                     isManagementAuthorized(resource.data.get('parentEventOwnerId', ''));
      
      // 4. Admin Ops: Listing and deletion are restricted to authorized management
      // Note: Any authenticated user can list records matching their own email/uid
      allow list: if isAuthenticated() && (
        isAdmin() || 
        isKnownAdmin() || 
        request.auth.token.email != null ||
        isManagementAuthorized(request.query.filters.get('parentEventOwnerId', ''))
      );
      allow delete: if isManagementAuthorized(resource.data.get('parentEventOwnerId', ''));
    }

    // --- SOCIAL INTERACTIONS (Likes, Comments & Relationships) ---
    match /likes/{id} {
      allow read, list: if true;
      allow create, delete: if isAuthenticated() || request.resource.data.userId != null;
    }
    
    match /comments/{id} {
      allow read, list: if true;
      allow create: if isAuthenticated() || request.resource.data.userId != null;
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }

    match /eventLikes/{id} {
      allow read, list: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    match /eventComments/{id} {
      allow read, list: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }

    match /relationships/{relId} {
      allow read, list: if true;
      allow write: if isAuthenticated() && (
        (request.resource != null && request.auth.uid == request.resource.data.followerId) ||
        (resource != null && request.auth.uid == resource.data.followerId) ||
        isAdmin()
      );
    }


    match /users/{userId} {
      allow read, list: if isAuthenticated() || userId.matches('^phone_[0-9]+$');
      allow create: if (isAuthenticated() && request.auth.uid == userId) || userId.matches('^phone_[0-9]+$');
      allow update: if (isAuthenticated() && (
        request.auth.uid == userId || 
        isKnownAdmin() || 
        isAdmin() || 
        (resource.data.get('delegatedBy', '') == request.auth.uid) || 
        (request.resource.data.get('delegatedBy', '') == request.auth.uid)
      )) || userId.matches('^phone_[0-9]+$');
      allow delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}