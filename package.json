{
  "name": "wedding-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "android": "npm --prefix apps/mobile run android",
    "ios": "npm --prefix apps/mobile run ios",
    "web": "npm --prefix apps/mobile run web",
    "lint": "eslint",
    "mobile": "cd apps/mobile && npm start",
    "mobile:android": "cd apps/mobile && npm run android",
    "mobile:ios": "cd apps/mobile && npm run ios",
    "mobile:web": "cd apps/mobile && npm run web",
    "mobile:lint": "cd apps/mobile && npm run lint",
    "mobile:install": "npm install --prefix apps/mobile",
    "dashboard": "npm --prefix apps/analytics-dashboard run dev",
    "dashboard:build": "npm --prefix apps/analytics-dashboard run build",
    "dashboard:preview": "npm --prefix apps/analytics-dashboard run preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "clsx": "^2.1.1",
    "expo": "^55.0.23",
    "face-api.js": "^0.22.2",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.83.6",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
