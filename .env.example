# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backblaze B2 media storage
B2_BUCKET_NAME=your_bucket_name
B2_BUCKET_ID=your_bucket_id
B2_ENDPOINT=s3.region.backblazeb2.com
B2_REGION=your_region
B2_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key

# Cloudflare media delivery
CLOUDFLARE_DOMAIN=example.com
MEDIA_DOMAIN=media.example.com
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_ZONE_ID=your_zone_id

# Mobile upload backend
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Automated Sweeper / Cron Configuration (Optional secret to secure cron trigger)
CRON_SECRET=your_optional_cron_secret_token

# Upstash QStash Queue Configuration (For background image resizing)
QSTASH_TOKEN=your_qstash_token


